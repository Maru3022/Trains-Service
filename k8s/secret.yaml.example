# Пример Secret (НЕ коммитьте реальные значения).
# Создание в кластере:
#   kubectl -n trains-service create secret generic trains-service-secret \
#     --from-literal=DB_PASSWORD='your-password'
#
# apiVersion: v1
# kind: Secret
# metadata:
#   name: trains-service-secret
#   namespace: trains-service
# type: Opaque
# stringData:
#   DB_PASSWORD: "change-me"
